# ============================================
# Suite Application Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# All Vite variables must start with VITE_ to be exposed to the frontend

# ── Supabase Configuration ──────────────────
# Required for authentication, database, and storage
# Get these from: https://app.supabase.com/project/_/settings/api

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
# Optional explicit auth redirect target for email confirmations
# Useful in containers/codespaces where localhost in email links may be wrong
# Example: https://<your-forwarded-url>/login
VITE_AUTH_REDIRECT_URL=
# Optional allowlist for auth redirect origins in frontend validation
# Example: http://localhost:5173,https://suite.example.com
VITE_AUTH_ALLOWED_ORIGINS=
# Optional passkey rollout gate for frontend UI
VITE_AUTH_PASSKEY_ENABLED=false
# Optional Cloudflare Turnstile site key for auth forms
VITE_TURNSTILE_SITE_KEY=
# Keep honeypot field aligned with backend AUTH_EMAIL_HONEYPOT_FIELD
VITE_AUTH_HONEYPOT_FIELD=company

# ── ZeroClaw Agent Configuration ────────────
# Optional - only needed if using the AI agent features
# ZeroClaw agent gateway endpoint for AI-powered automation

VITE_AGENT_URL=http://127.0.0.1:3000
VITE_AGENT_GATEWAY_URL=http://127.0.0.1:3000
VITE_AGENT_TIMEOUT=30000
# Required by default for agent task execution
VITE_AGENT_WEBHOOK_SECRET=
# Default: true. Set to false only for local troubleshooting.
VITE_AGENT_REQUIRE_WEBHOOK_SECRET=true
# Agent transport mode (direct = browser talks to gateway, backend = brokered)
VITE_AGENT_TRANSPORT=direct
# When using backend transport, the frontend talks to this path (proxied in dev)
VITE_AGENT_BROKER_URL=/api/agent

# ── Dev Admin Access (Command Center) ──────
# Development-only admin allowlist for /app/command-center
# Use one of the options below:
VITE_DEV_ADMIN_EMAIL=your-email@example.com
# VITE_DEV_ADMIN_EMAILS=you@example.com,teammate@example.com

# ── Ground-Grid-Generation Backend ──────────
# Optional - only needed for AutoCAD integration features
# Python Flask API server for AutoCAD COM automation (Windows only)

VITE_COORDINATES_BACKEND_URL=http://localhost:5000
# Dev server proxy target for backend /api endpoints
# Used by Vite only (dev). In production, prefer reverse-proxying under the same origin.
VITE_BACKEND_URL=http://localhost:5000
# Terminal workflow defaults
# Auto-connect/sync terminal workflow on tab load
VITE_TERMINAL_AUTO_CONNECT=true
# Comma-separated block name allowlist for terminal strip scan profile
VITE_TERMINAL_BLOCK_ALLOW_LIST=TB_STRIP_META_SIDE

# Optional .NET AutoDraft API target for backend proxy mode
# When set, backend /api/autodraft/plan and /execute proxy to this URL first.
AUTODRAFT_DOTNET_API_URL=

# Conduit Route AutoCAD provider
# com (default) | dotnet | dotnet_fallback_com
CONDUIT_ROUTE_AUTOCAD_PROVIDER=com
# Named-pipe settings for dotnet providers
AUTOCAD_DOTNET_PIPE_NAME=SUITE_AUTOCAD_PIPE
AUTOCAD_DOTNET_TIMEOUT_MS=30000
# Optional request token forwarded to .NET bridge payloads
AUTOCAD_DOTNET_TOKEN=
# Optional local AutoCAD install hints for building src/components/apps/dxfer
# Example: C:\Program Files\Autodesk\AutoCAD 2026
AUTOCAD_INSTALL_DIR=
# Used by EtapDxfCleanup.csproj when selecting default framework/reference set
AUTOCAD_VERSION=2026

# ── API Security ─────────────────────────────
# API key for authenticating requests to backend services
# IMPORTANT: Change this in production! This key is used by:
# - Coordinates Grabber API (Flask backend)
# Generate a secure key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

VITE_API_KEY=dev-only-insecure-key-change-in-production
# Backend-only secret (not exposed to the frontend bundle)
# Local development requirement: API_KEY must exactly match VITE_API_KEY.
API_KEY=
# AutoCAD/backend auth defaults to bearer token. API-key fallback is optional and disabled by default.
AUTOCAD_ALLOW_API_KEY_FALLBACK=false
# /ws accepts one-time ticket auth by default. Keep API-key websocket fallback disabled for production hardening.
WS_ALLOW_API_KEY_FALLBACK=false
# One-time websocket ticket controls
WS_TICKET_TTL_SECONDS=45
WS_TICKET_MAX_ENTRIES=20000
# Optional: bind tickets to requesting remote IP (usually false behind proxies)
WS_TICKET_BIND_REMOTE_ADDR=false

# ── Backend-Only Agent Broker (Recommended) ─
# These values are used by the Python backend to broker pairing + webhook calls.
# Do NOT prefix with VITE_ (these are server-only).

# Supabase backend auth (needed to validate session tokens server-side)
SUPABASE_URL=
# Preferred: service role key for server-side auth lookups
SUPABASE_SERVICE_ROLE_KEY=
# Alternative: Legacy HS256 JWT secret (leave empty if using new ECC keys)
SUPABASE_JWT_SECRET=
# Optional fallback for dev-only auth lookups (not recommended for prod)
SUPABASE_ANON_KEY=
# Optional explicit redirect base for backend-triggered auth emails
# Example: https://suite.example.com
AUTH_EMAIL_REDIRECT_URL=
# Allowed origins for backend auth email redirects (comma-separated)
AUTH_ALLOWED_REDIRECT_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Optional passkey rollout flags
AUTH_PASSKEY_ENABLED=false
# supabase | external | first-party
AUTH_PASSKEY_PROVIDER=supabase
# First-party WebAuthn settings (required when AUTH_PASSKEY_PROVIDER=first-party)
# Local dev defaults usually:
# AUTH_PASSKEY_RP_ID=localhost
# AUTH_PASSKEY_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AUTH_PASSKEY_RP_ID=localhost
AUTH_PASSKEY_RP_NAME=Suite
AUTH_PASSKEY_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AUTH_PASSKEY_WEBAUTHN_STATE_TTL_SECONDS=300
AUTH_PASSKEY_WEBAUTHN_STATE_MAX_ENTRIES=10000
AUTH_PASSKEY_WEBAUTHN_TIMEOUT_MS=60000
AUTH_PASSKEY_REQUIRE_USER_VERIFICATION=true
AUTH_PASSKEY_REQUIRE_RESIDENT_KEY=true
# Optional external provider details (used only when AUTH_PASSKEY_PROVIDER=external)
AUTH_PASSKEY_EXTERNAL_NAME=External IdP
# Optional external passkey start URLs (required for external provider mode)
# Example ZeroClaw bridge endpoint:
# AUTH_PASSKEY_EXTERNAL_SIGNIN_URL=http://127.0.0.1:42617/suite/passkey/callback
# External provider should honor Suite redirect hints and emit provider JWT claims token when suite_claims_required=1.
AUTH_PASSKEY_EXTERNAL_SIGNIN_URL=
AUTH_PASSKEY_EXTERNAL_ENROLL_URL=
# Optional metadata/discovery URL for provider diagnostics/documentation
AUTH_PASSKEY_EXTERNAL_DISCOVERY_URL=
# One-time callback state controls for passkey redirect completion
AUTH_PASSKEY_CALLBACK_STATE_TTL_SECONDS=900
AUTH_PASSKEY_CALLBACK_STATE_MAX_ENTRIES=10000
# Require signed external callback payloads (recommended for gateway integration)
AUTH_PASSKEY_REQUIRE_SIGNED_CALLBACK=true
# Shared secret used to verify callback signatures from external passkey provider
# If using ZeroClaw bridge, set this to the same value as:
# ZC_SUITE_PASSKEY_CALLBACK_SIGNING_SECRET (gateway env)
AUTH_PASSKEY_CALLBACK_SIGNING_SECRET=
# Reject callbacks older than this many seconds based on signed timestamp
AUTH_PASSKEY_CALLBACK_SIGNATURE_MAX_AGE_SECONDS=300
# Allow limited provider/server clock drift for signed callback timestamps
AUTH_PASSKEY_CALLBACK_SIGNATURE_MAX_CLOCK_SKEW_SECONDS=90
# Optional auth abuse controls for passwordless email-link endpoint
AUTH_EMAIL_HONEYPOT_FIELD=company
AUTH_EMAIL_WINDOW_SECONDS=900
AUTH_EMAIL_MAX_ATTEMPTS=6
AUTH_EMAIL_MIN_INTERVAL_SECONDS=15
AUTH_EMAIL_BLOCK_SECONDS=1800
# Additional per-IP limiter (helps when attackers rotate emails from one IP)
AUTH_EMAIL_IP_WINDOW_SECONDS=900
AUTH_EMAIL_IP_MAX_ATTEMPTS=30
AUTH_EMAIL_IP_BLOCK_SECONDS=1800
AUTH_EMAIL_MIN_RESPONSE_MS=450
AUTH_EMAIL_RESPONSE_JITTER_MS=120
# Optional Cloudflare Turnstile server-side validation
AUTH_EMAIL_TURNSTILE_SECRET=
AUTH_EMAIL_TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify
AUTH_EMAIL_TURNSTILE_TIMEOUT_SECONDS=5
# If true and Turnstile secret is configured, missing/invalid token is rejected.
AUTH_EMAIL_REQUIRE_TURNSTILE=true

# ZeroClaw gateway (local) and webhook secret
AGENT_GATEWAY_URL=http://127.0.0.1:3000
AGENT_WEBHOOK_SECRET=

# Session cookie settings for agent broker
AGENT_SESSION_TTL_SECONDS=21600
AGENT_SESSION_SECURE=false
AGENT_SESSION_SAMESITE=Strict
# Email verification challenge controls for brokered pair/unpair actions
AGENT_PAIRING_CHALLENGE_TTL_SECONDS=900
AGENT_PAIRING_CHALLENGE_MAX_ENTRIES=10000
# Route in the Suite app that receives email-link verification callbacks
AGENT_PAIRING_REDIRECT_PATH=/app/agent
# Additional abuse controls for pair/unpair challenge + confirm
AGENT_PAIRING_ACTION_WINDOW_SECONDS=900
AGENT_PAIRING_ACTION_MAX_ATTEMPTS=8
AGENT_PAIRING_ACTION_MIN_INTERVAL_SECONDS=20
AGENT_PAIRING_ACTION_BLOCK_SECONDS=1800
AGENT_PAIRING_CONFIRM_FAILURE_WINDOW_SECONDS=900
AGENT_PAIRING_CONFIRM_FAILURE_MAX_ATTEMPTS=6
AGENT_PAIRING_CONFIRM_FAILURE_BLOCK_SECONDS=1800
# Require webhook secret for broker requests (recommended)
AGENT_REQUIRE_WEBHOOK_SECRET=true

# ============================================
# Notes:
# ============================================
# - All VITE_* variables are embedded in the frontend bundle
#   DO NOT put sensitive secrets here (use backend env vars instead)
# - The Supabase anon key is safe to expose (it's row-level security enforced)
# - Agent and backend URLs default to localhost for development
# - Production deployments should override these with actual domains
