{
	"name": "vite-react-typescript-starter",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "npm run arch:ensure && vite",
		"dev:full": "node scripts/dev-full.mjs",
		"dev:all": "npm run dev:full",
		"build": "npm run arch:ensure && vite build",
		"preview": "vite preview",
		"backend:coords:dev": "node scripts/run-backend-dev.mjs",
		"watchdog:collector": "python scripts/run-watchdog-filesystem-collector.py",
		"watchdog:collector:once": "python scripts/run-watchdog-filesystem-collector.py --once",
		"watchdog:autocad:collector": "python scripts/run-watchdog-autocad-state-collector.py",
		"watchdog:autocad:collector:once": "python scripts/run-watchdog-autocad-state-collector.py --once",
		"watchdog:autocad:plugin:build": "dotnet build dotnet/watchdog-cad-tracker/WatchdogCadTracker.csproj -v minimal",
		"watchdog:autocad:plugin:install": "PowerShell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/install-watchdog-autocad-plugin.ps1",
		"watchdog:autocad:plugin:check": "PowerShell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/check-watchdog-autocad-plugin.ps1",
		"watchdog:autocad:doctor": "PowerShell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/check-watchdog-autocad-readiness.ps1",
		"watchdog:startup:install": "PowerShell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/install-watchdog-filesystem-collector-startup.ps1",
		"watchdog:startup:check": "PowerShell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/check-watchdog-filesystem-collector-startup.ps1",
		"watchdog:startup:autocad:install": "PowerShell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/install-watchdog-autocad-collector-startup.ps1",
		"watchdog:startup:autocad:check": "PowerShell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/check-watchdog-autocad-collector-startup.ps1",
		"watchdog:backend:startup:check": "PowerShell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/check-watchdog-backend-startup.ps1",
		"watchdog:backend:startup:start": "PowerShell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/check-watchdog-backend-startup.ps1 -StartIfMissing",
		"gateway:startup:check": "PowerShell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/check-gateway-startup.ps1",
		"gateway:startup:start": "PowerShell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/check-gateway-startup.ps1 -StartIfMissing",
		"frontend:startup:check": "PowerShell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/check-suite-frontend-startup.ps1",
		"frontend:startup:start": "PowerShell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/check-suite-frontend-startup.ps1 -StartIfMissing",
		"workstation:sync": "PowerShell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/sync-suite-workstation-profile.ps1",
		"workstation:mirror": "PowerShell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/sync-suite-local-state.ps1",
		"workstation:restore": "PowerShell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/restore-suite-local-state.ps1",
		"workstation:bootstrap": "PowerShell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/run-suite-runtime-startup.ps1",
		"workstation:stop": "PowerShell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/stop-suite-runtime.ps1 -IncludeFrontend",
		"workstation:control-panel": "PowerShell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/launch-suite-runtime-control.ps1",
		"workstation:control-panel:legacy": "PowerShell.exe -NoProfile -Sta -ExecutionPolicy Bypass -File scripts/open-suite-runtime-control.ps1",
		"workstation:startup:install": "PowerShell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/install-suite-runtime-startup.ps1",
		"supabase:start": "node scripts/run-supabase-cli.mjs start",
		"supabase:stop": "node scripts/run-supabase-cli.mjs stop",
		"supabase:status": "node scripts/run-supabase-cli.mjs status",
		"supabase:db:reset": "node scripts/run-supabase-cli.mjs db reset --local --yes",
		"supabase:types": "node scripts/generate-supabase-types-local.mjs",
		"supabase:env:local": "node scripts/write-supabase-local-env.mjs",
		"supabase:env:clear": "node scripts/clear-supabase-local-env.mjs",
		"supabase:mode:local": "node scripts/write-supabase-local-env.mjs --ensure-running --restart-if-running",
		"supabase:mode:hosted": "node scripts/clear-supabase-local-env.mjs",
		"supabase:mail:gmail": "node scripts/write-supabase-local-env.mjs --ensure-running --restart-if-running --mail gmail --strict-mail",
		"supabase:mail:mailpit": "node scripts/write-supabase-local-env.mjs --ensure-running --restart-if-running --mail mailpit",
		"supabase:remote:login": "node scripts/run-supabase-cli.mjs login",
		"supabase:remote:target:auto": "node scripts/set-supabase-remote-project-ref.mjs",
		"supabase:remote:preflight": "node scripts/run-supabase-remote-workflow.mjs preflight",
		"supabase:remote:push:dry": "node scripts/run-supabase-remote-workflow.mjs push --dry-run",
		"supabase:remote:push": "node scripts/run-supabase-remote-workflow.mjs push",
		"supabase:remote:task:install": "PowerShell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/install-supabase-remote-preflight-task.ps1",
		"worktale:bootstrap": "node scripts/bootstrap-worktale.mjs",
		"worktale:doctor": "node scripts/check-worktale-readiness.mjs",
		"gateway:dev": "node scripts/run-agent-gateway.mjs",
		"auth:playwright:bootstrap": "node scripts/bootstrap-playwright-auth-state.mjs",
		"auth:magiclink:generate": "node scripts/generate-auth-magiclink.mjs",
		"arch:ensure": "node scripts/ensure-architecture-model.mjs",
		"arch:verify": "node scripts/ensure-architecture-model.mjs --verify",
		"arch:generate": "node scripts/generate-architecture-model.mjs",
		"env:sync": "node scripts/sync-env-from-example.mjs",
		"env:sync:dry": "node scripts/sync-env-from-example.mjs --dry",
		"env:check": "node scripts/check-env-parity.mjs",
		"typecheck": "tsc --noEmit -p tsconfig.app.json",
		"guard:eslint": "node scripts/guard-eslint.mjs",
		"guard:appearance": "node scripts/guard-appearance-debt.mjs",
		"guard:tailwind": "node scripts/guard-no-tailwind.mjs",
		"check": "npm run arch:verify && npm run env:check && npm run guard:eslint && npm run guard:appearance && npm run guard:tailwind && biome lint src backend dotnet scripts && npm run typecheck",
		"check:fix": "biome check --write src backend dotnet scripts",
		"lint": "biome lint src backend dotnet scripts",
		"lint:fix": "biome lint --write src backend dotnet scripts",
		"format": "biome format src backend dotnet scripts",
		"format:write": "biome format --write src backend dotnet scripts",
		"ci:audit": "npm audit --audit-level=high",
		"test:unit": "vitest run --exclude \"**/autodraft upgrade/**\"",
		"test:unit:watch": "vitest --exclude \"**/autodraft upgrade/**\"",
		"test:e2e": "playwright test",
		"test:e2e:list": "playwright test --list",
		"deps:python:lock": "python -m piptools compile backend/requirements-api.in --output-file backend/requirements-api.lock.txt && python -m piptools compile backend/Transmittal-Builder/requirements.in --output-file backend/Transmittal-Builder/requirements.lock.txt"
	},
	"dependencies": {
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@floating-ui/react": "^0.27.18",
		"@hcaptcha/react-hcaptcha": "^2.0.2",
		"@radix-ui/react-avatar": "^1.1.11",
		"@radix-ui/react-scroll-area": "^1.2.10",
		"@radix-ui/react-separator": "^1.1.8",
		"@radix-ui/react-switch": "^1.2.6",
		"@react-three/drei": "^10.7.7",
		"@react-three/fiber": "^9.5.0",
		"@react-three/rapier": "^2.2.0",
		"@simplewebauthn/browser": "^13.2.2",
		"@supabase/supabase-js": "^2.98.0",
		"@types/d3": "^7.4.3",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"d3": "^7.9.0",
		"date-fns": "^4.1.0",
		"exceljs": "^4.4.0",
		"js-yaml": "^4.1.1",
		"lucide-react": "^0.575.0",
		"pdfjs-dist": "^5.5.207",
		"radix-ui": "^1.4.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-router-dom": "^7.13.0",
		"three": "^0.183.1",
		"yaml": "^2.8.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@playwright/test": "^1.58.2",
		"@testing-library/react": "^16.3.2",
		"@types/js-yaml": "^4.0.9",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/three": "^0.183.1",
		"@vitejs/plugin-react": "^5.1.4",
		"autoprefixer": "^10.4.18",
		"jsdom": "^28.1.0",
		"postcss": "^8.5.8",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.0.18"
	}
}
