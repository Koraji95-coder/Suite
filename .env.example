# ============================================
# Suite Application Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# Keep machine-local overrides in .env.local when you need workstation-specific settings.
# All Vite variables must start with VITE_ to be exposed to the frontend

# ── Supabase Configuration ──────────────────
# Required for authentication, database, and storage
# Get these from: https://app.supabase.com/project/_/settings/api
# Local Supabase helper flow:
#   npm run supabase:start
#   npm run supabase:mode:local
#   npm run supabase:mode:hosted
# The generated .env.local overlay switches DEV admin checks to hybrid mode locally and keeps hosted mode opt-in.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
# Optional explicit auth redirect target for email confirmations
# Useful in containers/codespaces where localhost in email links may be wrong
# Example: https://<your-forwarded-url>/login
VITE_AUTH_REDIRECT_URL=
# Optional allowlist for auth redirect origins in frontend validation
# Example: http://localhost:5173,https://suite.example.com
VITE_AUTH_ALLOWED_ORIGINS=
# Optional passkey rollout gate for frontend UI
VITE_AUTH_PASSKEY_ENABLED=false
# Optional Cloudflare Turnstile site key for auth forms
VITE_TURNSTILE_SITE_KEY=
# Keep honeypot field aligned with backend AUTH_EMAIL_HONEYPOT_FIELD
VITE_AUTH_HONEYPOT_FIELD=company

# ── Suite Agent Configuration ───────────────
# Optional - only needed if using the AI agent features
# Suite-native agent gateway endpoint for AI-powered automation

VITE_AGENT_URL=http://127.0.0.1:3001
VITE_AGENT_GATEWAY_URL=http://127.0.0.1:3001
# Direct-mode connect/handshake timeout (capped at 30s)
VITE_AGENT_CONNECT_TIMEOUT_MS=30000
# Health check timeout for both direct and broker transport (ms)
VITE_AGENT_HEALTH_TIMEOUT_MS=8000
VITE_AGENT_TIMEOUT=30000
# Max direct-chat stream runtime after connect succeeds (20m default)
VITE_AGENT_STREAM_MAX_MS=1200000
# Required by default for agent task execution
VITE_AGENT_WEBHOOK_SECRET=
# Default: true. Set to false only for local troubleshooting.
VITE_AGENT_REQUIRE_WEBHOOK_SECRET=true
# Agent transport mode (direct = browser talks to gateway, backend = brokered)
VITE_AGENT_TRANSPORT=backend
# When using backend transport, the frontend talks to this path (proxied in dev)
VITE_AGENT_BROKER_URL=/api/agent
# Optional frontend orchestration diagnostics (console logger traces)
VITE_AGENT_DEBUG_ORCHESTRATION=false
# Optional frontend profile-model routing overrides (used in direct transport)
VITE_AGENT_MODEL_KORO_PRIMARY=qwen3:14b
VITE_AGENT_MODEL_DEVSTRAL_PRIMARY=devstral-small-2:latest
VITE_AGENT_MODEL_SENTINEL_PRIMARY=gemma3:12b
VITE_AGENT_MODEL_FORGE_PRIMARY=qwen2.5-coder:14b
VITE_AGENT_MODEL_DRAFTSMITH_PRIMARY=joshuaokolo/C3Dv0:latest
VITE_AGENT_MODEL_GRIDSAGE_PRIMARY=ALIENTELLIGENCE/electricalengineerv2:latest
# Trusted direct-mode pairing restore window (hours, max 720)
VITE_AGENT_PAIRING_RESTORE_WINDOW_HOURS=24
# Local-only convenience mode: disable trusted pairing window expiry checks.
VITE_AGENT_PAIRING_RESTORE_NO_EXPIRY=false
# Direct-mode token TTL (hours). Set to 0 to disable expiry for local-only sessions.
VITE_AGENT_TOKEN_TTL_HOURS=24
# Default secure behavior: unpair on sign-out. Set false for local convenience sessions.
VITE_AGENT_SIGNOUT_UNPAIR=true
# Frontend chat transcript safety limits (prevents runaway browser memory usage)
VITE_AGENT_CHAT_MAX_MESSAGES_PER_CONVERSATION=200
VITE_AGENT_CHAT_MAX_MESSAGE_CHARS=12000
# Deprecated and ignored in current runtime: VITE_AGENT_MODEL_*_FALLBACKS

# ── Dev Admin Access (Command Center) ──────
# Development-only admin allowlist for /app/command-center
# Admin source in DEV: hybrid | supabase | allowlist
VITE_DEV_ADMIN_SOURCE=supabase
# Use one of the options below:
VITE_DEV_ADMIN_EMAIL=your-email@example.com
# VITE_DEV_ADMIN_EMAILS=you@example.com,teammate@example.com

# ── Ground-Grid-Generation Backend ──────────
# Optional - only needed for AutoCAD integration features
# Python Flask API server for AutoCAD COM automation (Windows only)

VITE_COORDINATES_BACKEND_URL=http://localhost:5000
# Dev server proxy target for backend /api endpoints
# Used by Vite only (dev). In production, prefer reverse-proxying under the same origin.
VITE_BACKEND_URL=http://localhost:5000
# Terminal workflow defaults
# Auto-connect/sync terminal workflow on tab load
VITE_TERMINAL_AUTO_CONNECT=true
# Comma-separated block name allowlist for terminal strip scan profile
VITE_TERMINAL_BLOCK_ALLOW_LIST=TB_STRIP_META_SIDE
# Terminal label sync endpoint strategy
# legacy (default): always call /api/conduit-route/terminal-labels/sync (COM path)
# auto: use bridge endpoint only when CAD provider is dotnet and sender is ready
# bridge: always call /api/conduit-route/bridge/terminal-labels/sync
VITE_CONDUIT_TERMINAL_LABEL_SYNC_MODE=legacy

# .NET AutoDraft API target for backend proxy mode
# Default if unset: http://127.0.0.1:5275
# Override when your .NET service runs on a different host/port.
AUTODRAFT_DOTNET_API_URL=http://127.0.0.1:5275
# AutoDraft compare agent-first review (advisory only; deterministic compare remains authoritative)
AUTODRAFT_COMPARE_AGENT_PRE_REVIEW_ENABLED=true
AUTODRAFT_COMPARE_AGENT_PRE_REVIEW_PROFILE=draftsmith
AUTODRAFT_COMPARE_AGENT_PRE_REVIEW_TIMEOUT_MS=30000
AUTODRAFT_COMPARE_AGENT_PRE_REVIEW_MAX_CASES=20

# Conduit Route AutoCAD provider
# com (default) | dotnet | dotnet_fallback_com
CONDUIT_ROUTE_AUTOCAD_PROVIDER=com
# Named-pipe settings for dotnet providers
AUTOCAD_DOTNET_PIPE_NAME=SUITE_AUTOCAD_PIPE
AUTOCAD_DOTNET_TIMEOUT_MS=30000
# Optional named-pipe listener/worker concurrency tuning (dotnet bridge)
AUTOCAD_DOTNET_MAX_PIPE_INSTANCES=4
AUTOCAD_DOTNET_MAX_PIPE_WORKERS=2
# Optional request token forwarded to .NET bridge payloads
AUTOCAD_DOTNET_TOKEN=
# Optional local AutoCAD install hints for building src/components/apps/dxfer
# Example: C:\Program Files\Autodesk\AutoCAD 2026
AUTOCAD_INSTALL_DIR=
# Used by EtapDxfCleanup.csproj when selecting default framework/reference set
AUTOCAD_VERSION=2026

# ── API Security ─────────────────────────────
# API key for authenticating requests to backend services
# IMPORTANT: Change this in production! This key is used by:
# - Coordinates Grabber API (Flask backend)
# Generate a secure key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

VITE_API_KEY=dev-only-insecure-key-change-in-production
# Backend-only secret (not exposed to the frontend bundle)
# Local development requirement: API_KEY must exactly match VITE_API_KEY.
API_KEY=
# Rate-limit storage backend (set one shared backend in production)
# Example: redis://localhost:6379/0
API_LIMITER_STORAGE_URI=redis://127.0.0.1:6379/0
# Optional fallback alias used by backend limiter resolver
REDIS_URL=
# When true in non-strict mode, backend falls back to memory:// if Redis is unreachable.
API_LIMITER_DEV_DEGRADE_ON_REDIS_FAILURE=true
# Redis reachability probe timeout for limiter bootstrap (milliseconds).
API_LIMITER_REDIS_PROBE_TIMEOUT_MS=800
# Require shared limiter storage even outside production mode.
# Set true for production-like runs that must fail fast when Redis is unavailable.
API_REQUIRE_SHARED_LIMITER_STORAGE=false
# Dev launcher helper (`npm run dev:full`): auto-start Docker Redis when unavailable
SUITE_DEV_AUTOSTART_REDIS=true
# Optional Docker Redis overrides for local dev helper
SUITE_REDIS_CONTAINER_NAME=suite-redis-local
SUITE_REDIS_DATA_VOLUME=suite_redis_local_data
SUITE_REDIS_IMAGE=redis:7-alpine
# Flask dev-server guardrails (local-only; use gunicorn/waitress/etc in production)
API_ALLOW_FLASK_DEV_SERVER=true
API_DEV_SERVER_THREADED=false
# AutoCAD/backend auth defaults to bearer token. API-key fallback is optional and disabled by default.
AUTOCAD_ALLOW_API_KEY_FALLBACK=false
# /ws accepts one-time ticket auth by default. Keep API-key websocket fallback disabled for production hardening.
WS_ALLOW_API_KEY_FALLBACK=false
# One-time websocket ticket controls
WS_TICKET_TTL_SECONDS=45
WS_TICKET_MAX_ENTRIES=20000
# Optional: bind tickets to requesting remote IP (usually false behind proxies)
WS_TICKET_BIND_REMOTE_ADDR=false

# ── Backend-Only Agent Broker (Recommended) ─
# These values are used by the Python backend to broker pairing + webhook calls.
# Do NOT prefix with VITE_ (these are server-only).
# Broker health proxy timeout when calling the local gateway /health endpoint
AGENT_HEALTH_PROXY_TIMEOUT_SECONDS=8

# Supabase backend auth (needed to validate session tokens server-side)
SUPABASE_URL=
# Preferred: service role key for server-side auth lookups
SUPABASE_SERVICE_ROLE_KEY=
# Alternative: Legacy HS256 JWT secret (leave empty if using new ECC keys)
SUPABASE_JWT_SECRET=
# Optional fallback for dev-only auth lookups (not recommended for prod)
SUPABASE_ANON_KEY=
# Hosted project ref used by guarded remote migration helpers
SUPABASE_REMOTE_PROJECT_REF=
# Optional workstation-local status artifact directory for sign-in preflight + push logs
SUITE_SUPABASE_SYNC_STATUS_DIR=
# Gmail + Supabase custom SMTP settings (for Auth email delivery).
# Note: Supabase does not auto-read these from your app env. Mirror these values in:
# Supabase Dashboard -> Authentication -> Settings -> SMTP Settings.
GMAIL_SMTP_USER=your-email@gmail.com
GMAIL_SMTP_APP_PASSWORD=
SUPABASE_SMTP_HOST=smtp.gmail.com
SUPABASE_SMTP_PORT=465
SUPABASE_SMTP_USER=your-email@gmail.com
SUPABASE_SMTP_PASS=
SUPABASE_SMTP_SENDER_EMAIL=your-email@gmail.com
SUPABASE_SMTP_SENDER_NAME=Suite
# Local Supabase email-mode helpers write these into .env.local:
#   npm run supabase:mail:gmail
#   npm run supabase:mail:mailpit
# Optional local override for Supabase analytics/Vector.
# On Windows, Suite disables it by default because Docker Desktop does not expose
# tcp://localhost:2375 unless you opt into Docker's insecure daemon export.
SUITE_SUPABASE_LOCAL_ANALYTICS_ENABLED=
SUITE_SUPABASE_LOCAL_EMAIL_MODE=
SUPABASE_LOCAL_SMTP_HOST=
SUPABASE_LOCAL_SMTP_PORT=
SUPABASE_LOCAL_SMTP_USER=
SUPABASE_LOCAL_SMTP_PASS=
SUPABASE_LOCAL_SMTP_ADMIN_EMAIL=
SUPABASE_LOCAL_SMTP_SENDER_NAME=
# Optional explicit redirect base for backend-triggered auth emails
# Example: https://suite.example.com
AUTH_EMAIL_REDIRECT_URL=
# Allowed origins for backend auth email redirects (comma-separated)
AUTH_ALLOWED_REDIRECT_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Optional passkey rollout flags
AUTH_PASSKEY_ENABLED=false
# supabase | external | first-party
AUTH_PASSKEY_PROVIDER=supabase
# First-party WebAuthn settings (required when AUTH_PASSKEY_PROVIDER=first-party)
# Local dev defaults usually:
# AUTH_PASSKEY_RP_ID=localhost
# AUTH_PASSKEY_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AUTH_PASSKEY_RP_ID=localhost
AUTH_PASSKEY_RP_NAME=Suite
AUTH_PASSKEY_ALLOWED_ORIGINS=http://localhost:5173
AUTH_PASSKEY_WEBAUTHN_STATE_TTL_SECONDS=300
AUTH_PASSKEY_WEBAUTHN_STATE_MAX_ENTRIES=10000
AUTH_PASSKEY_WEBAUTHN_TIMEOUT_MS=60000
AUTH_PASSKEY_REQUIRE_USER_VERIFICATION=true
AUTH_PASSKEY_REQUIRE_RESIDENT_KEY=true
# Optional external provider details (used only when AUTH_PASSKEY_PROVIDER=external)
AUTH_PASSKEY_EXTERNAL_NAME=External IdP
# Optional external passkey start URLs (required for external provider mode)
# Example ZeroClaw bridge endpoint:
# AUTH_PASSKEY_EXTERNAL_SIGNIN_URL=http://127.0.0.1:42617/suite/passkey/callback
# External provider should honor Suite redirect hints and emit provider JWT claims token when suite_claims_required=1.
AUTH_PASSKEY_EXTERNAL_SIGNIN_URL=
AUTH_PASSKEY_EXTERNAL_ENROLL_URL=
# Optional metadata/discovery URL for provider diagnostics/documentation
AUTH_PASSKEY_EXTERNAL_DISCOVERY_URL=
# One-time callback state controls for passkey redirect completion
AUTH_PASSKEY_CALLBACK_STATE_TTL_SECONDS=900
AUTH_PASSKEY_CALLBACK_STATE_MAX_ENTRIES=10000
# Require signed external callback payloads (recommended for gateway integration)
AUTH_PASSKEY_REQUIRE_SIGNED_CALLBACK=true
# Shared secret used to verify callback signatures from external passkey provider
# If using ZeroClaw bridge, set this to the same value as:
# ZC_SUITE_PASSKEY_CALLBACK_SIGNING_SECRET (gateway env)
AUTH_PASSKEY_CALLBACK_SIGNING_SECRET=
# Reject callbacks older than this many seconds based on signed timestamp
AUTH_PASSKEY_CALLBACK_SIGNATURE_MAX_AGE_SECONDS=300
# Allow limited provider/server clock drift for signed callback timestamps
AUTH_PASSKEY_CALLBACK_SIGNATURE_MAX_CLOCK_SKEW_SECONDS=90
# Optional auth abuse controls for passwordless email-link endpoint
AUTH_EMAIL_HONEYPOT_FIELD=company
AUTH_EMAIL_WINDOW_SECONDS=900
AUTH_EMAIL_MAX_ATTEMPTS=6
AUTH_EMAIL_MIN_INTERVAL_SECONDS=15
AUTH_EMAIL_BLOCK_SECONDS=1800
# Additional per-IP limiter (helps when attackers rotate emails from one IP)
AUTH_EMAIL_IP_WINDOW_SECONDS=900
AUTH_EMAIL_IP_MAX_ATTEMPTS=30
AUTH_EMAIL_IP_BLOCK_SECONDS=1800
AUTH_EMAIL_MIN_RESPONSE_MS=450
AUTH_EMAIL_RESPONSE_JITTER_MS=120
# Optional Cloudflare Turnstile server-side validation
AUTH_EMAIL_TURNSTILE_SECRET=
AUTH_EMAIL_TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify
AUTH_EMAIL_TURNSTILE_TIMEOUT_SECONDS=5
# If true and Turnstile secret is configured, missing/invalid token is rejected.
AUTH_EMAIL_REQUIRE_TURNSTILE=false

# ZeroClaw gateway (local) and webhook secret
AGENT_GATEWAY_URL=http://127.0.0.1:3001
AGENT_WEBHOOK_SECRET=
# Comma-separated CORS allow-list for browser direct-mode calls to gateway.
# Use "*" only for local troubleshooting.
ZEROCLAW_GATEWAY_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Gateway provider mode for Suite launcher:
# local = always force local provider (default)
# auto = local unless an explicit cloud provider is configured
# config = respect ~/.zeroclaw/config.toml provider as-is
SUITE_AGENT_PROVIDER_MODE=local
# Local-provider defaults used when Suite selects local mode.
SUITE_LOCAL_PROVIDER=ollama
SUITE_LOCAL_AGENT_MODEL=devstral-small-2:latest
# Provider credentials used by Suite-native gateway model calls when cloud routing is enabled.
# Leave empty for local Ollama-only workflows.
# Set only when intentionally using OpenRouter/cloud providers.
OPENROUTER_API_KEY=

# Session cookie settings for agent broker
# Set to 604800 (7 days) for week-long pairing persistence in local workflows.
AGENT_SESSION_TTL_SECONDS=21600
AGENT_SESSION_SECURE=false
AGENT_SESSION_SAMESITE=Strict
# Agent session persistence backend (Redis-backed by default when available)
AGENT_SESSION_REDIS_ENABLED=true
# Fail backend startup if Redis session storage is requested but unavailable.
AGENT_SESSION_REDIS_REQUIRED=false
# Optional explicit Redis URL for agent sessions. If empty, falls back to
# API_LIMITER_STORAGE_URI when redis://, then REDIS_URL.
AGENT_SESSION_REDIS_URL=
AGENT_SESSION_REDIS_KEY_PREFIX=suite:agent:session:
AGENT_SESSION_REDIS_TIMEOUT_MS=800
# Email verification challenge controls for brokered pair/unpair actions
AGENT_PAIRING_CHALLENGE_TTL_SECONDS=900
AGENT_PAIRING_CHALLENGE_MAX_ENTRIES=10000
# Route in the Suite app used for pairing email redirects (recommended: /login)
AGENT_PAIRING_REDIRECT_PATH=/login
# Additional abuse controls for pair/unpair challenge + confirm
AGENT_PAIRING_ACTION_WINDOW_SECONDS=900
AGENT_PAIRING_ACTION_MAX_ATTEMPTS=8
AGENT_PAIRING_ACTION_MIN_INTERVAL_SECONDS=20
AGENT_PAIRING_ACTION_BLOCK_SECONDS=1800
AGENT_PAIRING_CONFIRM_FAILURE_WINDOW_SECONDS=900
AGENT_PAIRING_CONFIRM_FAILURE_MAX_ATTEMPTS=6
AGENT_PAIRING_CONFIRM_FAILURE_BLOCK_SECONDS=1800
# Require webhook secret for broker requests (recommended)
AGENT_REQUIRE_WEBHOOK_SECRET=true
# Max /webhook SSE runtime window in gateway before terminal timeout event
ZEROCLAW_GATEWAY_STREAM_MAX_SECS=1200
# Persistent backend ledger for multi-agent orchestration runs
AGENT_RUN_LEDGER_PATH=backend/agent-runs.sqlite3
# Max profiles executed in parallel per orchestration stage.
# Default behavior: 2 in local Ollama mode, otherwise 4.
AGENT_ORCHESTRATION_MAX_PARALLEL_PROFILES=2
# Optional verbose orchestration diagnostics in backend logs.
# Set true to log per-step gateway attempt start/response/latency details.
AGENT_ORCHESTRATION_VERBOSE_LOGS=false
# Optional backend profile-model routing overrides (used in broker transport)
AGENT_MODEL_KORO_PRIMARY=qwen3:14b
AGENT_MODEL_DEVSTRAL_PRIMARY=devstral-small-2:latest
AGENT_MODEL_SENTINEL_PRIMARY=gemma3:12b
AGENT_MODEL_FORGE_PRIMARY=qwen2.5-coder:14b
AGENT_MODEL_DRAFTSMITH_PRIMARY=joshuaokolo/C3Dv0:latest
AGENT_MODEL_GRIDSAGE_PRIMARY=ALIENTELLIGENCE/electricalengineerv2:latest
# Deprecated and ignored in current runtime: AGENT_MODEL_*_FALLBACKS

# ============================================
# Notes:
# ============================================
# - All VITE_* variables are embedded in the frontend bundle
#   DO NOT put sensitive secrets here (use backend env vars instead)
# - The Supabase anon key is safe to expose (it's row-level security enforced)
# - Agent and backend URLs default to localhost for development
# - Production deployments should override these with actual domains
